# Copy to secrets.env and fill in values.

# Server
HTTP_PORT=3000
HTTPS_PORT=3443

# Postgres: either paste the full URI, OR leave DATABASE_URL empty and set SUPABASE_DB_PASSWORD
# (Database password from Project Settings → Database — not anon/service_role keys).
DATABASE_URL=
SUPABASE_DB_PASSWORD=
SUPABASE_URL=https://[project-ref].supabase.co

# Optional — @supabase/supabase-js (see src/config/supabaseClient.js)
# SUPABASE_SERVICE_ROLE_KEY=   # server-only; bypasses RLS
# SUPABASE_ANON_KEY=             # legacy JWT anon key
# SUPABASE_PUBLISHABLE_KEY=      # OR new dashboard “publishable” key (sb_publishable_…)
# Same as Next.js templates (if you copy-paste):
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Local Postgres only: disable SSL
# DATABASE_SSL=false

# JWT
JWT_SECRET=change-me-in-production

# HTTPS (optional PEM paths)
SSL_KEY_PATH=./src/config/certs/server.key.pem
SSL_CERT_PATH=./src/config/certs/server.cert.pem
